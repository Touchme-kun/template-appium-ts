  "fieldValidation": {
    "firstName": {
      "minLength": 1,
      "maxLength": 50,
      "pattern": "^[a-zA-Z\\s'-]+$",
      "required": true
    },
    "lastName": {
      "minLength": 1,
      "maxLength": 50,
      "pattern": "^[a-zA-Z\\s'-]+$",
      "required": true
    },
    "email": {
      "minLength": 5,
      "maxLength": 254,
      "pattern": "^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$",
      "required": true
    },
    "password": {
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&])[A-Za-z\\d@$!%*?&]+$",
      "required": true
    },
    "phone": {
      "minLength": 10,
      "maxLength": 15,
      "pattern": "^\\+?[1-9]\\d{9,14}$",
      "required": false
    }
  },
  "specialCharacterTests": {
    "names": [
