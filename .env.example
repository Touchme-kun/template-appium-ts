# ===========================================
# Mobile Automation Framework - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ===========================================
# General Settings
# ===========================================
NODE_ENV=development
LOG_LEVEL=info
BASE_URL=https://api.example.com

# ===========================================
# Environment Selection
# ===========================================
# Options: dev, staging, prod
TEST_ENVIRONMENT=staging

# ===========================================
# Appium Server Configuration
# ===========================================
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# ===========================================
# Android Configuration
# ===========================================
ANDROID_DEVICE_NAME=Pixel_7_API_33
ANDROID_PLATFORM_VERSION=13
ANDROID_APP_PATH=./apps/android/app-debug.apk
ANDROID_APP_PACKAGE=com.example.app
ANDROID_APP_ACTIVITY=com.example.app.MainActivity

# ===========================================
# iOS Configuration
# ===========================================
IOS_DEVICE_NAME=iPhone 15 Pro
IOS_PLATFORM_VERSION=17.0
IOS_APP_PATH=./apps/ios/App.app
IOS_BUNDLE_ID=com.example.app
IOS_UDID=

# iOS Signing (for real devices)
XCODE_ORG_ID=
XCODE_SIGNING_ID=iPhone Developer

# ===========================================
# BrowserStack Configuration
# ===========================================
BROWSERSTACK_USERNAME=your_username
BROWSERSTACK_ACCESS_KEY=your_access_key
BROWSERSTACK_APP_ID=bs://your-android-app-id
BROWSERSTACK_IOS_APP_ID=bs://your-ios-app-id
BROWSERSTACK_APP_PATH=./apps/android/app-release.apk
BROWSERSTACK_LOCAL=false
BROWSERSTACK_LOCAL_IDENTIFIER=

# ===========================================
# CI/CD Configuration
# ===========================================
BUILD_NUMBER=
CI=false

# ===========================================
# Reporting & Notifications
# ===========================================
ALLURE_RESULTS_DIR=./allure-results
SLACK_WEBHOOK=
EMAIL_NOTIFICATIONS=false

# ===========================================
# Test Data
# ===========================================
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=SecurePass123

# ===========================================
# Debug Settings
# ===========================================
DEBUG_MODE=false
CAPTURE_SCREENSHOTS=true
CAPTURE_VIDEO=false
