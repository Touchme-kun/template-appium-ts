{
  "name": "mobile-automation-framework",
  "version": "1.0.0",
  "description": "Enterprise-grade mobile test automation framework for iOS and Android using Appium, TypeScript, and WebdriverIO",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist allure-results allure-report",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"configs/**/*.ts\"",
    "test": "wdio run configs/wdio.conf.ts",
    "test:smoke": "wdio run configs/wdio.smoke.conf.ts",
    "test:android": "wdio run configs/wdio.android.conf.ts",
    "test:ios": "wdio run configs/wdio.ios.conf.ts",
    "test:docker": "wdio run configs/wdio.docker.conf.ts",
    "test:mcash:login:browserstack": "cross-env BROWSERSTACK_PLATFORM=android wdio run configs/wdio.browserstack.conf.ts --spec tests/specs/android/mcash.login.spec.ts",
    "test:mcash:login:debug" : "wdio run configs/wdio.android.conf.ts --spec tests/specs/android/mcash.login.spec.ts --logLevel trace",
    "test:mcash:login": "wdio run configs/wdio.android.conf.ts --spec tests/specs/android/mcash.login.spec.ts",
    "test:android:browserstack": "cross-env BROWSERSTACK_PLATFORM=android wdio run configs/wdio.browserstack.conf.ts",
    "test:ios:browserstack": "cross-env BROWSERSTACK_PLATFORM=ios wdio run configs/wdio.browserstack.conf.ts",
    "test:cucumber:android:browserstack": "cross-env BROWSERSTACK_PLATFORM=android wdio run configs/wdio.browserstack.cucumber.conf.ts",
    "test:cucumber:ios:browserstack": "cross-env BROWSERSTACK_PLATFORM=ios wdio run configs/wdio.browserstack.cucumber.conf.ts",
    "test:cucumber:smoke:browserstack": "cross-env BROWSERSTACK_PLATFORM=android CUCUMBER_TAGS=@smoke wdio run configs/wdio.browserstack.cucumber.conf.ts",
    "test:cucumber:regression:browserstack": "cross-env BROWSERSTACK_PLATFORM=android CUCUMBER_TAGS=@regression wdio run configs/wdio.browserstack.cucumber.conf.ts",
    "test:cucumber:p1:browserstack": "cross-env BROWSERSTACK_PLATFORM=android CUCUMBER_TAGS=@P1 wdio run configs/wdio.browserstack.cucumber.conf.ts",
    "test:cucumber:dry:browserstack:android": "cross-env BROWSERSTACK_PLATFORM=android CUCUMBER_TAGS=@smoke wdio run configs/wdio.browserstack.cucumber.conf.ts -- --cucumberOpts.dryRun",
    "test:cucumber:dry:browserstack:ios": "cross-env BROWSERSTACK_PLATFORM=ios CUCUMBER_TAGS=@smoke wdio run configs/wdio.browserstack.cucumber.conf.ts -- --cucumberOpts.dryRun",
    "test:cucumber": "wdio run configs/wdio.cucumber.conf.ts",
    "test:cucumber:smoke": "cross-env CUCUMBER_TAGS=@smoke wdio run configs/wdio.cucumber.conf.ts",
    "test:cucumber:regression": "cross-env CUCUMBER_TAGS=@regression wdio run configs/wdio.cucumber.conf.ts",
    "test:cucumber:p1": "cross-env CUCUMBER_TAGS=@P1 wdio run configs/wdio.cucumber.conf.ts",
    "test:cucumber:login": "cross-env CUCUMBER_TAGS=@login wdio run configs/wdio.cucumber.conf.ts",
    "test:cucumber:registration": "cross-env CUCUMBER_TAGS=@registration wdio run configs/wdio.cucumber.conf.ts",
    "test:cucumber:navigation": "cross-env CUCUMBER_TAGS=@navigation wdio run configs/wdio.cucumber.conf.ts",
    "test:cucumber:negative": "cross-env CUCUMBER_TAGS=@negative wdio run configs/wdio.cucumber.conf.ts",
    "test:cucumber:wip": "cross-env CUCUMBER_TAGS=@wip wdio run configs/wdio.cucumber.conf.ts",
    "test:cucumber:dry": "cross-env CUCUMBER_TAGS=@smoke wdio run configs/wdio.cucumber.conf.ts -- --cucumberOpts.dryRun",
    "allure:prepare": "ts-node scripts/allure-utils.ts prepare",
    "allure:history": "ts-node scripts/allure-utils.ts preserve-history",
    "allure:clean": "ts-node scripts/allure-utils.ts clean",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "allure:report": "npm run allure:history && npm run allure:generate && npm run allure:open",
    "report": "npm run allure:report",
    "report:generate": "npm run allure:history && npm run allure:generate",
    "report:ci": "npm run allure:prepare && npm run allure:generate",
    "npm:interactive": "ts-node scripts/npm-interactive.ts",
    "docker:build": "docker build -f docker/Dockerfile -t mobile-automation:latest --target development .",
    "docker:build:prod": "docker build -f docker/Dockerfile -t mobile-automation:prod --target production .",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "docker:logs": "docker-compose -f docker/docker-compose.yml logs -f test-runner",
    "docker:shell": "docker-compose -f docker/docker-compose.yml run --rm test-runner sh",
    "docker:clean": "docker-compose -f docker/docker-compose.yml down -v && docker system prune -f",
    "docker:appium": "docker-compose -f docker/docker-compose.yml up -d appium",
    "docker:allure": "docker-compose -f docker/docker-compose.yml --profile reporting up -d allure",
    "docker:browserstack:qa": "docker-compose -f docker/docker-compose.yml --env-file .env.qa run --rm test-runner-browserstack npm run test:cucumber:android:browserstack",
    "docker:browserstack:preprod": "docker-compose -f docker/docker-compose.yml --env-file .env.preprod run --rm test-runner-browserstack npm run test:cucumber:android:browserstack",
    "docker:browserstack:prod": "docker-compose -f docker/docker-compose.yml --env-file .env.prod run --rm test-runner-browserstack npm run test:cucumber:android:browserstack",
    "docker:browserstack:smoke:qa": "docker-compose -f docker/docker-compose.yml --env-file .env.qa run --rm test-runner-browserstack npm run test:cucumber:smoke:browserstack",
    "docker:browserstack:smoke:preprod": "docker-compose -f docker/docker-compose.yml --env-file .env.preprod run --rm test-runner-browserstack npm run test:cucumber:smoke:browserstack",
    "docker:browserstack:smoke:prod": "docker-compose -f docker/docker-compose.yml --env-file .env.prod run --rm test-runner-browserstack npm run test:cucumber:smoke:browserstack",
    "docker:browserstack:regression:qa": "docker-compose -f docker/docker-compose.yml --env-file .env.qa run --rm test-runner-browserstack npm run test:cucumber:regression:browserstack",
    "docker:browserstack:regression:preprod": "docker-compose -f docker/docker-compose.yml --env-file .env.preprod run --rm test-runner-browserstack npm run test:cucumber:regression:browserstack",
    "docker:browserstack:regression:prod": "docker-compose -f docker/docker-compose.yml --env-file .env.prod run --rm test-runner-browserstack npm run test:cucumber:regression:browserstack",
    "docker:local:qa": "docker-compose -f docker/docker-compose.yml --env-file .env.qa up test-runner",
    "docker:local:preprod": "docker-compose -f docker/docker-compose.yml --env-file .env.preprod up test-runner",
    "docker:local:prod": "docker-compose -f docker/docker-compose.yml --env-file .env.prod up test-runner",
    "docker:local:smoke:qa": "docker-compose -f docker/docker-compose.yml --env-file .env.qa run --rm test-runner npm run test:cucumber:smoke",
    "docker:local:smoke:preprod": "docker-compose -f docker/docker-compose.yml --env-file .env.preprod run --rm test-runner npm run test:cucumber:smoke",
    "docker:local:smoke:prod": "docker-compose -f docker/docker-compose.yml --env-file .env.prod run --rm test-runner npm run test:cucumber:smoke",
    "prepare": "husky install"
  },
  "keywords": [
    "appium",
    "mobile-automation",
    "webdriverio",
    "typescript",
    "ios",
    "android",
    "bdd",
    "cucumber",
    "allure"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@wdio/allure-reporter": "^9.22.0",
    "@wdio/appium-service": "^9.23.0",
    "@wdio/browserstack-service": "^9.23.0",
    "@wdio/cli": "^9.23.0",
    "@wdio/cucumber-framework": "^9.23.0",
    "@wdio/globals": "^9.23.0",
    "@wdio/local-runner": "^9.23.0",
    "@wdio/mocha-framework": "^9.23.0",
    "@wdio/spec-reporter": "^9.20.0",
    "@wdio/types": "^9.20.0",
    "allure-commandline": "^2.25.0",
    "appium": "^3.1.2",
    "appium-uiautomator2-driver": "^6.7.8",
    "appium-xcuitest-driver": "^10.14.4",
    "chai": "^4.3.10",
    "cross-env": "^10.1.0",
    "dotenv": "^16.3.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "expect-webdriverio": "^5.6.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "winston": "^3.11.0"
  },
  "dependencies": {
    "@faker-js/faker": "^8.3.1",
    "@gavrix/appium-mcp": "^0.3.0",
    "webdriverio": "^9.23.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
