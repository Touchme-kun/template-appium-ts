{
  "name": "template-appium-ts",
  "version": "1.0.0",
  "description": "Enterprise-grade mobile test automation framework for iOS and Android using Appium, TypeScript, and WebdriverIO",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist allure-results allure-report",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"configs/**/*.ts\"",
    "test:android": "wdio run configs/wdio.android.conf.ts",
    "test:ios": "wdio run configs/wdio.ios.conf.ts",
    "test:android:smoke": "wdio run configs/wdio.android.conf.ts --suite smoke",
    "test:android:e2e": "wdio run configs/wdio.android.conf.ts --suite e2e",
    "test:android:regression": "wdio run configs/wdio.android.conf.ts --suite regression",
    "test:ios:smoke": "wdio run configs/wdio.ios.conf.ts --suite smoke",
    "test:ios:e2e": "wdio run configs/wdio.ios.conf.ts --suite e2e",
    "test:ios:regression": "wdio run configs/wdio.ios.conf.ts --suite regression",
    "test:browserstack:android": "cross-env TEST_ENV=qa wdio run configs/wdio.browserstack.android.conf.ts",
    "test:browserstack:ios": "cross-env TEST_ENV=qa wdio run configs/wdio.browserstack.ios.conf.ts",
    "allure:prepare": "ts-node scripts/allure-utils.ts prepare",
    "allure:history": "ts-node scripts/allure-utils.ts preserve-history",
    "allure:clean": "ts-node scripts/allure-utils.ts clean",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "report": "npm run allure:history && npm run allure:generate && npm run allure:open",
    "report:ci": "npm run allure:prepare && npm run allure:generate",
    "logs:cleanup": "ts-node scripts/cleanup-logs.ts all",
    "logs:archive": "ts-node scripts/cleanup-logs.ts archive",
    "logs:clean": "ts-node scripts/cleanup-logs.ts clean",
    "docker:build": "docker build -f docker/Dockerfile -t mobile-automation:latest --target development .",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "docker:clean": "docker-compose -f docker/docker-compose.yml down -v && docker system prune -f",
    "prepare": "husky install"
  },
  "keywords": [
    "appium",
    "mobile-automation",
    "webdriverio",
    "typescript",
    "ios",
    "android",
    "mocha",
    "tdd",
    "allure",
    "template",
    "boilerplate"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@wdio/allure-reporter": "^9.22.0",
    "@wdio/appium-service": "^9.23.0",
    "@wdio/browserstack-service": "^9.23.0",
    "@wdio/cli": "^9.23.0",
    "@wdio/globals": "^9.23.0",
    "@wdio/local-runner": "^9.23.0",
    "@wdio/mocha-framework": "^9.23.0",
    "@wdio/spec-reporter": "^9.20.0",
    "@wdio/types": "^9.20.0",
    "allure-commandline": "^2.25.0",
    "appium": "^3.1.2",
    "appium-uiautomator2-driver": "^6.7.8",
    "appium-xcuitest-driver": "^10.14.4",
    "chai": "^4.3.10",
    "cross-env": "^10.1.0",
    "dotenv": "^16.3.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "expect-webdriverio": "^5.6.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "winston": "^3.11.0"
  },
  "dependencies": {
    "@faker-js/faker": "^8.3.1",
    "@gavrix/appium-mcp": "^0.3.0",
    "webdriverio": "^9.23.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}